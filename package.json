{
  "name": "eidos",
  "version": "0.21.0",
  "private": true,
  "type": "module",
  "description": "Eidos is an extensible framework for managing your personal data throughout your lifetime in one place.",
  "author": "mayneyao",
  "scripts": {
    "dev": "pnpm run --filter web-app dev",
    "dev:desktop": "pnpm run --filter desktop dev",
    "build": "pnpm run --filter web-app build",
    "build:desktop": "pnpm run --filter desktop build",
    "pkg": "pnpm run --filter desktop package",
    "pkg:dev": "pnpm run --filter desktop package:dev",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "patch": "node scripts/version.cjs patch",
    "minor": "node scripts/version.cjs minor",
    "major": "node scripts/version.cjs major",
    "test": "vitest"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^3.7.2",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-esm-shim": "^0.1.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.9",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/d3": "^7.4.0",
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.14.195",
    "@types/mime-db": "^1.43.5",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.4.1",
    "@types/papaparse": "^5.3.7",
    "@types/uuid": "^9.0.2",
    "@types/ws": "^8.5.5",
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^5.61.0",
    "@vitejs/plugin-react": "^4.0.3",
    "@vitejs/plugin-react-oxc": "^0.2.3",
    "autoprefixer": "^10.4.14",
    "clsx": "^1.2.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^8.44.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "eslint-plugin-tailwindcss": "^3.13.0",
    "postcss": "^8.4.25",
    "prebuild-install": "^7.1.3",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^5.9.2",
    "semver": "^7.6.2",
    "shx": "^0.3.4",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.3.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-pwa": "^0.20.1",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.5.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "next",
        "solid-js",
        "svelte",
        "vue"
      ]
    }
  },
  "packageManager": "pnpm@10.12.4+sha512.5ea8b0deed94ed68691c9bad4c955492705c5eeb8a87ef86bc62c74a26b037b08ff9570f108b2e4dbd1dd1a9186fea925e527f141c648e85af45631074680184"
}