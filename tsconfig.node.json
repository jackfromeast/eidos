{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "vite.config.ts",
    "config/**/*",
    "apps/web-app/vite.config.ts",
    "apps/desktop/vite.config.ts",
    "packages/shared/**/*"
  ]
}