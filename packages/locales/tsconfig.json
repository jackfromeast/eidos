{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "noEmit": false,
        "emitDeclarationOnly": true
    },
    "include": [
        "./**/*.ts",
        "./**/*.json",
    ],
    "exclude": [
        "node_modules",
        "dist",
        "tsconfig.json"
    ]
}